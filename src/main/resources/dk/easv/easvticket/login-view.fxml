<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="210.0" prefWidth="210.0" spacing="20.0" stylesheets="@CSS/style.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.easvticket.LoginController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <TextField maxWidth="200.0" promptText="user name" styleClass="loginFiled" />
      <TextField maxWidth="200.0" promptText="password" styleClass="loginFiled" />
      <Button mnemonicParsing="false" onAction="#onLogin" styleClass="loginBtn" text="login" />
   </children>
</VBox>
