<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" stylesheets="@CSS/style.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.easvticket.EventDetails">
   <children>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
         <children>
            <VBox prefHeight="200.0" prefWidth="200.0" />
            <VBox prefHeight="200.0" prefWidth="200.0" />
            <VBox prefHeight="200.0" prefWidth="200.0" />
         </children>
      </HBox>
      <HBox prefHeight="100.0" prefWidth="200.0">
          <children>
              <VBox prefHeight="200.0" prefWidth="200.0" />
              <VBox prefHeight="200.0" prefWidth="200.0" />
              <VBox prefHeight="200.0" prefWidth="200.0" />
          </children>
      </HBox>
      <HBox prefHeight="200.0" prefWidth="200.0">
         <children>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="600.0">
               <children>
                  <TextField fx:id="txtUserFilter">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" top="5.0" />
                     </VBox.margin>
                  </TextField>
                  <TableView fx:id="tbvUser" prefHeight="200.0" prefWidth="200.0">
                    <columns>
                      <TableColumn fx:id="tbvCollumUsername" prefWidth="75.0" text="Username" />
                      <TableColumn fx:id="tbvCollumName" prefWidth="75.0" text="name" />
                        <TableColumn fx:id="tbvCollumEmail" prefWidth="75.0" text="email" />
                        <TableColumn fx:id="tbvCollumRemove" prefWidth="75.0" text="remove button" />
                    </columns>
                     <VBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </VBox.margin>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  <Button mnemonicParsing="false" onAction="#onAddCoordinator" text="add coordinator">
                     <VBox.margin>
                        <Insets bottom="5.0" />
                     </VBox.margin>
                  </Button>
               </children>
            </VBox>
         </children></HBox>
      <HBox alignment="BOTTOM_CENTER" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Button fx:id="btnDelete" mnemonicParsing="false" onAction="#onDelete" styleClass="detailsDelete" text="delete">
               <HBox.margin>
                  <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
               </HBox.margin>
            </Button>
            <Button fx:id="btnEdit" mnemonicParsing="false" onAction="#onEdit" styleClass="detailsEdit" text="edit">
               <HBox.margin>
                  <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
               </HBox.margin>
            </Button>
            <Button fx:id="btnClose" mnemonicParsing="false" onAction="#onClose" text="close">
               <HBox.margin>
                  <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
               </HBox.margin>
            </Button>
         </children></HBox>
   </children>
</VBox>
